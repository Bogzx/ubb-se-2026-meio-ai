<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Ubb_se_2026_meio_ai.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Ubb_se_2026_meio_ai"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Meio AI — Movie Reels Platform">

    <NavigationView
        x:Name="NavView"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        PaneDisplayMode="Left"
        SelectionChanged="NavView_SelectionChanged">

        <NavigationView.MenuItems>
            <NavigationViewItem Content="Reels Upload"   Tag="ReelsUpload"       Icon="Upload" />
            <NavigationViewItem Content="Trailer Scraping" Tag="TrailerScraping"  Icon="Globe" />
            <NavigationViewItem Content="Reels Editing"  Tag="ReelsEditing"       Icon="Edit" />
            <NavigationViewItem Content="Movie Swipe"    Tag="MovieSwipe"         Icon="Shuffle" />
            <NavigationViewItem Content="Movie Tournament" Tag="MovieTournament"  Icon="FourBars" />
            <NavigationViewItem Content="Personality Match" Tag="PersonalityMatch" Icon="People" />
            <NavigationViewItem Content="Reels Feed"     Tag="ReelsFeed"          Icon="Video" />
        </NavigationView.MenuItems>

        <Frame x:Name="ContentFrame" />
    </NavigationView>
</Window>
